{$DOMAIN:demo.kellywebsite.com} {
    encode gzip

    request_body {
        max_size 200MB
    }

    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /admin* {
        reverse_proxy backend:8000
    }

    handle /media/* {
        reverse_proxy backend:8000
    }

    handle {
        reverse_proxy frontend:5173
    }
}
