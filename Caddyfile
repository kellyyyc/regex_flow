{$DOMAIN:demo.kellywebsite.com} {
    encode gzip

    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /admin* {
        reverse_proxy backend:8000
    }

    handle_path /media/* {
        root * /srv/media
        header Content-Disposition "attachment"
        file_server
    }

    handle {
        reverse_proxy frontend:5173
    }
}
